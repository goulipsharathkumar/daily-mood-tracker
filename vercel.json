{
  "version": 2,
  "build": {
    "env": {
      "NODE_VERSION": "16",
      "NODE_OPTIONS": "--openssl-legacy-provider"
    }
  },
  "buildCommand": "npm install && npm run build",
  "outputDirectory": "build",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
